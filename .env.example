# =============================================================================
# Local development environment variables.
# Copy this file to `.env` and adjust as needed.
#
# Production uses managed services:
#   - Postgres + Storage: Supabase
#   - Redis:              Upstash
#   - Web:                Vercel
#   - API:                Railway
# Local dev uses the containers defined in docker-compose.yml.
# =============================================================================

# --- Ports ---
API_PORT=4000
WEB_PORT=3000

# --- PostgreSQL (local Docker; Supabase in production) ---
POSTGRES_USER=scheduling
POSTGRES_PASSWORD=scheduling_dev_password
POSTGRES_DB=scheduling
DATABASE_URL=postgresql://scheduling:scheduling_dev_password@localhost:5432/scheduling?schema=public

# --- Redis (local Docker; Upstash in production) ---
REDIS_URL=redis://localhost:6379

# --- MinIO (local S3-compatible; Supabase Storage in production) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_dev_password
MINIO_ENDPOINT=http://localhost:9000

# --- Auth / JWT ---
# Generate strong secrets in production (e.g. `openssl rand -base64 48`).
# Access tokens are short-lived and ride in Authorization headers.
# Refresh tokens are opaque random strings stored hashed in the DB and served
# to the browser via an HttpOnly, SameSite=Strict cookie.
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-prod-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-prod-min-32-chars
JWT_ACCESS_TTL=15m
# Refresh TTL in seconds. 30 days by default.
JWT_REFRESH_TTL_SECONDS=2592000

# Cookie signing secret. Used by @fastify/cookie. Distinct from JWT secrets.
COOKIE_SECRET=dev-cookie-secret-change-me-in-prod-min-32-chars

# Web origin (for CORS allowlist + secure cookie domain decisions).
WEB_ORIGIN=http://localhost:3000

# NODE_ENV controls cookie Secure flag (true in production, false in dev).
NODE_ENV=development
