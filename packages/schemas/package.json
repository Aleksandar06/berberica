{
  "name": "@scheduling/schemas",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Zod validation schemas — single source of truth for API + Web.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "clean": "rimraf dist .turbo",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "libphonenumber-js": "^1.11.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@scheduling/config": "workspace:*",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
