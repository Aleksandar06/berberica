// =============================================================================
// Multi-tenant Scheduling SaaS — Prisma schema
//
// Tenancy: every tenant-owned table carries `tenant_id` with FK to `tenants`.
// IDs:     UUIDs generated by `gen_random_uuid()` (PG 13+ built-in via pgcrypto
//          fallback; Postgres 16 includes it natively).
// Times:   timestamptz for absolute moments, time for clock-only fields,
//          date for calendar dates.
// Status enums: modeled as Postgres enums via Prisma `enum` — see rationale
//          near the enum declarations below.
//
// Things this schema does NOT express (delivered via raw SQL in the migration):
//   • Functional unique index on lower(tenants.slug)
//   • Reserved-slug CHECK
//   • Numeric / temporal range CHECKs (Prisma DSL has no CHECK primitive)
//   • btree_gist extension + booking overlap EXCLUDE constraint
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase / Neon poolers (pgbouncer transaction mode) reject the prepared
  // statements `prisma migrate` needs. Set DIRECT_URL to the non-pooled
  // connection string in production so `prisma migrate deploy` works; runtime
  // queries continue to flow through the pooled `url`. In local dev where
  // DIRECT_URL is unset, Prisma falls back to `url`.
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// ENUMS — Postgres enums (not lookup tables)
//
// Rationale: the value sets (role, booking status, tenant status, notification
// status) are tightly coupled to application logic, very stable, and benefit
// from compile-time type safety in the generated Prisma client. No JOIN
// needed to read them. The tradeoff (DDL needed to add values) is acceptable
// given how rarely these sets change. Lookup tables would only pay off if
// values were data-managed by admins, which they are not here.
// =============================================================================

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  STAFF
  CUSTOMER
}

enum TenantStatus {
  active
  suspended

  @@map("tenant_status")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
  no_show

  @@map("booking_status")
}

enum NotificationStatus {
  pending
  sent
  failed

  @@map("notification_status")
}

enum VerificationPurpose {
  account_email // user activation token (Step 11A)
  guest_otp     // 6-digit OTP bound to a booking intent
  guest_grant   // single-use grant emitted after successful OTP confirm

  @@map("verification_purpose")
}

// =============================================================================
// TENANTS
// =============================================================================

model Tenant {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  slug         String       @unique
  businessType String       @map("business_type")
  timezone     String       // IANA timezone, e.g. "Europe/Skopje"
  // ISO 4217 currency code used to format and aggregate prices across the
  // tenant's services + earnings reports. Per-tenant so a multi-region
  // marketplace can host EUR + MKD + USD venues side by side. Default EUR.
  currency     String       @default("EUR")
  status       TenantStatus @default(active)
  contactEmail String?      @map("contact_email")
  contactPhone String?      @map("contact_phone")
  address      String?
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt      @map("updated_at") @db.Timestamptz(6)

  settings                    TenantSettings?
  branding                    TenantBrandingAssets?
  userRoles                   TenantUserRole[]
  services                    Service[]
  staffMembers                StaffMember[]
  staffServices               StaffService[]
  availabilityRules           AvailabilityRule[]
  availabilityBreaks          AvailabilityBreak[]
  availabilityExceptions      AvailabilityException[]
  availabilityExceptionBreaks AvailabilityExceptionBreak[]
  customers                   Customer[]
  bookings                    Booking[]
  bookingAuditLogs            BookingAuditLog[]
  notificationEvents          NotificationEvent[]
  auditLogs                   AuditLog[]
  verificationCodes           VerificationCode[]

  @@map("tenants")
}

model TenantSettings {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                   String   @unique @map("tenant_id") @db.Uuid
  defaultSlotDurationMinutes Int      @default(15)  @map("default_slot_duration_minutes")
  bookingLeadTimeMinutes     Int      @default(0)   @map("booking_lead_time_minutes")
  bookingMaxDaysAhead        Int      @default(60)  @map("booking_max_days_ahead")
  allowGuestBooking          Boolean  @default(true) @map("allow_guest_booking")
  allowCustomerCancellation  Boolean  @default(true) @map("allow_customer_cancellation")
  cancellationCutoffMinutes  Int      @default(120) @map("cancellation_cutoff_minutes")
  allowCustomerReschedule    Boolean  @default(true) @map("allow_customer_reschedule")
  rescheduleCutoffMinutes    Int      @default(120) @map("reschedule_cutoff_minutes")
  cancellationPolicy         String?  @map("cancellation_policy")
  reschedulePolicy           String?  @map("reschedule_policy")
  // Step 11A — when true, authenticated-but-unverified users cannot finalize
  // a booking at this tenant. Default false to keep UX friction low.
  requireVerifiedAccountForBooking Boolean @default(false) @map("require_verified_account_for_booking")
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime @updatedAt      @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model TenantBrandingAssets {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @unique @map("tenant_id") @db.Uuid
  logoUrl        String?  @map("logo_url")
  primaryColor   String?  @map("primary_color")
  secondaryColor String?  @map("secondary_color")
  accentColor    String?  @map("accent_color")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt      @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_branding_assets")
}

// =============================================================================
// USERS & AUTH SCAFFOLDING (schema only — auth logic lands in Step 4)
// =============================================================================

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique
  passwordHash    String    @map("password_hash")
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  isActive        Boolean   @default(true) @map("is_active")
  // Email verification (flow implemented in Step 11A; flag exists now so
  // registration in Step 4 can mark new accounts as unverified).
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt      @map("updated_at") @db.Timestamptz(6)

  tenantRoles   TenantUserRole[]
  refreshTokens RefreshToken[]
  staffMember   StaffMember?
  customers     Customer[]

  @@map("users")
}

model TenantUserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      Role
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, role])
  @@index([tenantId])
  @@map("tenant_user_roles")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// =============================================================================
// SERVICES & STAFF
// =============================================================================

model Service {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  name                String
  description         String?
  durationMinutes     Int      @map("duration_minutes")
  bufferBeforeMinutes Int      @default(0) @map("buffer_before_minutes")
  bufferAfterMinutes  Int      @default(0) @map("buffer_after_minutes")
  // Service price in minor currency units (e.g. cents for EUR / USD,
  // denar-stotinka for MKD). Nullable: a `null` price means the venue
  // hasn't set one yet — surfaced as "Ask for price" in the UI rather
  // than a free service. Currency lives on the parent Tenant row.
  priceCents          Int?     @map("price_cents")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt      @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffServices StaffService[]
  bookings      Booking[]

  @@index([tenantId, isActive])
  @@map("services")
}

model StaffMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  userId      String?  @unique @map("user_id") @db.Uuid
  displayName String   @map("display_name")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt      @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  staffServices               StaffService[]
  availabilityRules           AvailabilityRule[]
  availabilityBreaks          AvailabilityBreak[]
  availabilityExceptions      AvailabilityException[]
  availabilityExceptionBreaks AvailabilityExceptionBreak[]
  bookings                    Booking[]

  @@index([tenantId, isActive])
  @@map("staff_members")
}

model StaffService {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  staffMemberId String   @map("staff_member_id") @db.Uuid
  serviceId     String   @map("service_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffMember StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffMemberId, serviceId])
  @@index([tenantId])
  @@map("staff_services")
}

// =============================================================================
// AVAILABILITY
//
// day_of_week convention: 0 = Sunday … 6 = Saturday (matches JS Date.getDay()).
// staff_member_id = NULL means tenant-wide (applies to every staff member).
// =============================================================================

model AvailabilityRule {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  staffMemberId       String?  @map("staff_member_id") @db.Uuid
  dayOfWeek           Int      @map("day_of_week")
  startTime           DateTime @map("start_time") @db.Time(0)
  endTime             DateTime @map("end_time")   @db.Time(0)
  slotDurationMinutes Int?     @map("slot_duration_minutes")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt      @map("updated_at") @db.Timestamptz(6)

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffMember StaffMember? @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@index([tenantId, dayOfWeek, isActive])
  @@index([tenantId, staffMemberId, dayOfWeek, isActive])
  @@map("availability_rules")
}

model AvailabilityBreak {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  staffMemberId String?  @map("staff_member_id") @db.Uuid
  dayOfWeek     Int      @map("day_of_week")
  startTime     DateTime @map("start_time") @db.Time(0)
  endTime       DateTime @map("end_time")   @db.Time(0)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt      @map("updated_at") @db.Timestamptz(6)

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffMember StaffMember? @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@index([tenantId, dayOfWeek, isActive])
  @@index([tenantId, staffMemberId, dayOfWeek, isActive])
  @@map("availability_breaks")
}

model AvailabilityException {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  staffMemberId   String?   @map("staff_member_id") @db.Uuid
  exceptionDate   DateTime  @map("exception_date") @db.Date
  isClosed        Boolean   @default(false) @map("is_closed")
  customStartTime DateTime? @map("custom_start_time") @db.Time(0)
  customEndTime   DateTime? @map("custom_end_time")   @db.Time(0)
  reason          String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt      @map("updated_at") @db.Timestamptz(6)

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffMember StaffMember? @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@index([tenantId, exceptionDate])
  @@index([tenantId, staffMemberId, exceptionDate])
  @@map("availability_exceptions")
}

model AvailabilityExceptionBreak {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  staffMemberId String?  @map("staff_member_id") @db.Uuid
  exceptionDate DateTime @map("exception_date") @db.Date
  startTime     DateTime @map("start_time") @db.Time(0)
  endTime       DateTime @map("end_time")   @db.Time(0)
  reason        String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt      @map("updated_at") @db.Timestamptz(6)

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffMember StaffMember? @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@index([tenantId, exceptionDate])
  @@index([tenantId, staffMemberId, exceptionDate])
  @@map("availability_exception_breaks")
}

// =============================================================================
// CUSTOMERS & BOOKINGS
// =============================================================================

model Customer {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  phone     String   // E.164 format, validated at the application layer
  email     String?
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt      @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  bookings Booking[]

  @@index([tenantId, userId])
  @@index([tenantId, phone])
  @@map("customers")
}

// -----------------------------------------------------------------------------
// Booking time convention (critical — drives the exclusion constraint):
//
//   start_at .. end_at  represents the *blocked range* on the staff member's
//   calendar, INCLUDING service buffers:
//
//       start_at = customer-facing start − service.buffer_before_minutes
//       end_at   = customer-facing end   + service.buffer_after_minutes
//
//   The half-open semantic [start_at, end_at) is enforced via tstzrange in
//   the EXCLUDE constraint (see migration), so a 10:00 end does NOT collide
//   with a 10:00 start. The customer-facing start/end are derivable from
//   start_at/end_at plus the linked service's buffer columns — we do not
//   denormalize them.
// -----------------------------------------------------------------------------

model Booking {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  staffMemberId String        @map("staff_member_id") @db.Uuid
  serviceId     String        @map("service_id") @db.Uuid
  customerId    String        @map("customer_id") @db.Uuid
  startAt       DateTime      @map("start_at") @db.Timestamptz(6)
  endAt         DateTime      @map("end_at")   @db.Timestamptz(6)
  status        BookingStatus @default(pending)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt      @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffMember   StaffMember         @relation(fields: [staffMemberId], references: [id], onDelete: Restrict)
  service       Service             @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  customer      Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  auditLogs     BookingAuditLog[]
  notifications NotificationEvent[]

  @@index([tenantId, staffMemberId, startAt])
  @@index([tenantId, customerId])
  @@map("bookings")
}

model BookingAuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  bookingId   String?  @map("booking_id") @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  metadata    Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([bookingId])
  @@map("booking_audit_logs")
}

// =============================================================================
// AUDIT LOG (Step 6)
//
// Generic audit trail for tenant-lifecycle and settings-mutation events.
// `tenantId` is nullable so platform-wide events (e.g. admin login, future
// global ops) can be recorded too. Booking-specific events stay in
// `booking_audit_logs` (which also retains the booking_id FK).
// =============================================================================

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  metadata    Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// =============================================================================
// VERIFICATION (Step 11A) — account-email tokens, guest OTPs, guest grants
// =============================================================================
//
// One table, three purposes:
//   • account_email — high-entropy token returned by registration. tenant_id
//     is NULL (account verification is a user-level concern, not tenant-
//     scoped). intent_hash NULL.
//   • guest_otp — 6-digit numeric code bound to (tenant, email, intent_hash).
//     `intent_hash = sha256(tenantId|serviceId|staffId|startAt)` so the code
//     can only be confirmed against the exact intent that requested it.
//   • guest_grant — single-use bearer issued after successful OTP confirm.
//     Bound to (tenant, email) only (NOT to a specific slot) so a 409 on
//     the booking insert doesn't force the guest to re-OTP for a new slot.
//
// `code_hash` is SHA-256 of the secret. For high-entropy account tokens this
// is fine; for low-entropy OTPs we rely on the per-row attempt counter +
// short expiry + per-IP rate limit (see service layer).
//
// Cleanup: rows older than 1 day past expiry are safe to GC. Today this is
// a documented manual query; Step 14 schedules a periodic job:
//   DELETE FROM verification_codes WHERE expires_at < NOW() - INTERVAL '1 day';
// =============================================================================

model VerificationCode {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String?             @map("tenant_id") @db.Uuid
  purpose      VerificationPurpose
  targetEmail  String              @map("target_email")
  codeHash     String              @map("code_hash")
  intentHash   String?             @map("intent_hash")
  expiresAt    DateTime            @map("expires_at") @db.Timestamptz(6)
  consumedAt   DateTime?           @map("consumed_at") @db.Timestamptz(6)
  attemptCount Int                 @default(0) @map("attempt_count")
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([targetEmail, purpose])
  @@index([expiresAt])
  @@index([tenantId, targetEmail, purpose])
  @@map("verification_codes")
}

model NotificationEvent {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // tenantId is nullable: Step 11A's account-email notifications are
  // user-level (a freshly registered user has no tenant yet). Booking-
  // related notifications still set it.
  tenantId  String?            @map("tenant_id") @db.Uuid
  bookingId String?            @map("booking_id") @db.Uuid
  type      String
  payload   Json               @default("{}") @db.JsonB
  status    NotificationStatus @default(pending)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([tenantId])
  @@map("notification_events")
}
