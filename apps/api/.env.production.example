# =============================================================================
# Production environment for @scheduling/api (Railway / Render / Fly).
#
# Set these in your hosting platform's env config — never commit real
# values. Generate JWT/cookie secrets with `openssl rand -base64 48`.
# =============================================================================

NODE_ENV=production

# Hosting platforms inject PORT. Don't set it manually.
# PORT=4000

# --- Postgres (Supabase, Neon, or Render) -----------------------------------
# Use the POOLED connection string from your provider:
#   Supabase: Settings → Database → Connection string → "Transaction" pooler
#   Neon:     Connection pooler URL (port 6543)
# Add `?sslmode=require&pgbouncer=true` if not already present.
DATABASE_URL=postgresql://postgres:<password>@<host>:6543/postgres?sslmode=require&pgbouncer=true

# Some providers (Supabase) need a separate DIRECT connection for prisma
# migrate. If set, the Prisma schema's `directUrl` will use it.
# DIRECT_URL=postgresql://postgres:<password>@<host>:5432/postgres?sslmode=require

# --- Redis (Upstash, Railway addon) -----------------------------------------
# Required for @nestjs/throttler's Redis-backed rate limiter.
REDIS_URL=redis://default:<password>@<host>:<port>

# --- Auth secrets (generate fresh per environment) --------------------------
JWT_ACCESS_SECRET=<openssl rand -base64 48>
JWT_REFRESH_SECRET=<openssl rand -base64 48>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_SECONDS=2592000
COOKIE_SECRET=<openssl rand -base64 48>

# --- Web origin allowlist (CORS) --------------------------------------------
# Comma-separated list of allowed origins. Include both the production
# domain AND any Vercel preview URLs you want to allow.
WEB_ORIGIN=https://glamora.vercel.app
